# jobify — pipeline environment (bring-your-own keys).
#
# Copy to `.env` in the repo root and fill in your own values:
#     cp .env.example .env
#
# This file configures the Python pipeline (jobify-hunt / jobify-tailor /
# jobify-submit). The dashboard has its OWN env file — see
# `dashboard/.env.local.example` (created by WS-B) for the Next.js cockpit.
#
# Legend:  [required]  must be set or the pipeline won't run
#          [optional]  safe to leave blank; the feature degrades off
#
# ─────────────────────────────────────────────────────────────────────────────
# Supabase — data + storage
# ─────────────────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com, then apply
# `jobify/migrations/0001_init.sql` (see docs/SETUP.md). Both URL and a
# SERVICE-ROLE key are required. The pipeline runs service-role only: the
# tables have RLS with no policies, so an anon key silently reads empty and
# jobify.db fails loud if handed one.
SUPABASE_URL=https://your-project.supabase.co              # [required] Project URL (Settings → API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key            # [required] Settings → API → service_role secret
SUPABASE_KEY=your-service-role-key                         # [required] legacy fallback name; set to the SAME service-role key

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic — the only LLM the pipeline calls
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...                         # [required] https://console.anthropic.com
# Max-plan OAuth fallback. Used only when ANTHROPIC_API_KEY is unset or has
# been benched by a billing/credit failure; spawns the bundled Claude Code
# CLI. Leave blank to stay on the API path.
CLAUDE_CODE_OAUTH_TOKEN=                                   # [optional] Max-plan fallback
# Model overrides (sensible defaults are baked in).
# TAILOR_CLAUDE_MODEL=claude-opus-4-8                      # [optional]
# SUBMITTER_CLAUDE_MODEL=claude-sonnet-4-6                 # [optional]

# ─────────────────────────────────────────────────────────────────────────────
# Profile — your personal "ground-truth" layer
# ─────────────────────────────────────────────────────────────────────────────
# Filesystem path to your profile dir (the eight persona files). Generated by
# the onboarding flow — see docs/ONBOARDING.md. Defaults to ./profile if unset.
JOBIFY_PROFILE_DIR=./profile                               # [optional] defaults to ./profile

# ─────────────────────────────────────────────────────────────────────────────
# Paid discovery sources (hunt only) — all optional
# ─────────────────────────────────────────────────────────────────────────────
# Free HTTP/RSS sources work without any of these. Add a key to widen reach.
SERPAPI_KEY=                                               # [optional] SerpAPI (Google Jobs + LinkedIn)
JSEARCH_API_KEY=                                           # [optional] JSearch via RapidAPI
JSEARCH_MAX_REQUESTS_PER_RUN=8                             # [optional]
JSEARCH_NUM_PAGES=2                                        # [optional]

# Hunter mode (also a --mode CLI arg). local_remote = Atlanta + Remote only
# (default); us_wide = also pulls non-remote US roles.
HUNTER_MODE=local_remote                                   # [optional]

# ─────────────────────────────────────────────────────────────────────────────
# Email digest (optional) — Resend
# ─────────────────────────────────────────────────────────────────────────────
# The hunt can email a morning digest of top fresh roles. Skip entirely if you
# only want the dashboard.
RESEND_API_KEY=                                            # [optional] https://resend.com
NOTIFY_FROM=Job Agent <jobs@example.com>                  # [optional] verified Resend sender
NOTIFY_TO=you@example.com                                  # [optional] where the digest lands

# ─────────────────────────────────────────────────────────────────────────────
# Submit / pre-fill (local visible-browser path) — optional knobs
# ─────────────────────────────────────────────────────────────────────────────
# The default jobify-submit path drives a LOCAL Chromium via Playwright and
# stops before the final submit click. None of these are required.
# REVIEW_DASHBOARD_URL=http://localhost:3000/review        # [optional] where review packets link
# PORTFOLIO_BASE_URL=http://localhost:3000                 # [optional] dashboard base URL for notify links
# JOBIFY_BROWSER_CDP=                                      # [optional] attach to an already-running Chrome (CDP URL)
# JOBIFY_BROWSER_PROFILE=                                  # [optional] persistent Chrome profile dir
# MAX_ATTEMPTS_PER_JOB=3                                   # [optional]

# ─────────────────────────────────────────────────────────────────────────────
# Browserbase — ONLY for the retired hosted-submit path (runner_legacy.py)
# ─────────────────────────────────────────────────────────────────────────────
# The current local-Playwright submit path does NOT use Browserbase. Leave
# blank unless you are intentionally running the legacy hosted runner.
BROWSERBASE_API_KEY=                                       # [optional] legacy hosted-submit only
BROWSERBASE_PROJECT_ID=                                    # [optional] legacy hosted-submit only
