# jobify hosted web app — copy to `.env.local` and fill in your own values:
#     cp .env.example .env.local
#
# No live Supabase project exists yet for the hosted product (infra
# decision deferred). Run everything against a local `supabase start`
# stack — see web/README.md for the full setup.

# ─────────────────────────────────────────────────────────────────────────
# Supabase — auth + profiles/invites/onboarding_sessions/budget_ledger
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321                # [required] `supabase status` after `supabase start`
NEXT_PUBLIC_SUPABASE_ANON_KEY=                                 # [required] `supabase status` -> anon key
SUPABASE_SERVICE_ROLE_KEY=                                     # [required, server-only] `supabase status` -> service_role key
                                                                # Used ONLY for the per-turn budget_ledger insert
                                                                # (lib/supabase/admin.ts) — never sent to the client.

# ─────────────────────────────────────────────────────────────────────────
# Anthropic — the onboarding chat's only LLM
# ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...                             # [required, server-only] https://console.anthropic.com
ONBOARDING_CLAUDE_MODEL=claude-sonnet-5                        # [optional] override the interview model
