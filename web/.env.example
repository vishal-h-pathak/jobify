# jobify hosted web app — copy to `.env.local` and fill in your own values:
#     cp .env.example .env.local
#
# No live Supabase project exists yet for the hosted product (infra
# decision deferred). Run everything against a local `supabase start`
# stack — see web/README.md for the full setup.

# ─────────────────────────────────────────────────────────────────────────
# Supabase — auth + profiles/invites/onboarding_sessions/budget_ledger
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321                # [required] `supabase status` after `supabase start`
NEXT_PUBLIC_SUPABASE_ANON_KEY=                                 # [required] `supabase status` -> anon key
SUPABASE_SERVICE_ROLE_KEY=                                     # [required, server-only] `supabase status` -> service_role key
                                                                # Bypasses RLS (lib/supabase/admin.ts) — the per-turn
                                                                # budget_ledger insert and the /api/admin/* routes
                                                                # (only after the requireAdmin() check passes). Never
                                                                # sent to the client.

# ─────────────────────────────────────────────────────────────────────────
# Anthropic — the onboarding chat's only LLM
# ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...                             # [required, server-only] https://console.anthropic.com
ONBOARDING_CLAUDE_MODEL=claude-sonnet-5                        # [optional] override the interview model

# ─────────────────────────────────────────────────────────────────────────
# Admin panel — /admin (invites, users, pool health)
# ─────────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=                                                  # [optional, server-only] comma-separated emails, e.g.
                                                                # "a@example.com,b@example.com" — a signed-in user whose
                                                                # email matches (case-insensitive, trimmed) is an admin.
                                                                # Unset = nobody is admin. See lib/admin/isAdmin.ts.

# ─────────────────────────────────────────────────────────────────────────
# User-triggered hunts — POST /api/hunt/run (HNT-1)
# ─────────────────────────────────────────────────────────────────────────
GITHUB_DISPATCH_TOKEN=                                         # [required, server-only] fine-grained GitHub PAT,
                                                                # Actions read/write on this repo. Dispatches
                                                                # hosted-hunt.yml. Unset = the trigger route 503s
                                                                # (logged), never crashes. Never sent to the client.
GITHUB_REPO=                                                   # [required, server-only] "owner/repo" — env var only,
                                                                # NOT hardcoded (the opensource scrub gate forbids the
                                                                # real slug as a literal in code).
HUNT_COOLDOWN_HOURS=6                                          # [optional, default 6] hours between one user's own
                                                                # hunt triggers. Admins bypass it entirely.
