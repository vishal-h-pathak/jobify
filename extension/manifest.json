{
  "manifest_version": 3,
  "name": "jobify submitter",
  "version": "0.1.0",
  "description": "Fills in job application forms from your tailored jobify materials. Stops before every final submit — you always click Submit yourself.",
  "key": "",
  "permissions": ["storage", "sidePanel", "activeTab"],
  "host_permissions": ["__APP_ORIGIN__/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "jobify"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.greenhouse.io/*", "*://*.lever.co/*", "*://*.ashbyhq.com/*", "*://*.myworkdayjobs.com/*", "*://*.workday.com/*"],
      "js": ["content/atsFillBridge.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["__APP_ORIGIN__/*"],
      "js": ["content/handoffRelay.js"],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ]
}
