# ── jobify dashboard — local env ──────────────────────────────────────
# Copy to .env.local and fill in. Never commit the real .env.local.

# Supabase (the pipeline writes rows here; the dashboard reads/updates them)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — server-only. Every dashboard data access uses this
# (RLS is on with no anon policies); never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — powers the optional chat / match-agent endpoint
ANTHROPIC_API_KEY=sk-ant-...

# Dashboard auth gate (middleware.ts). If unset, the dashboard is open;
# set a strong value for any shared/hosted use.
DASHBOARD_PASSWORD=choose-a-strong-password

# GitHub Actions dispatch — the Hunt / Tailor one-click buttons trigger
# workflow_dispatch on this repo. PAT needs `actions:write` scope.
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-pipeline-repo
GITHUB_PAT=github_pat_...

# Branding shown in the dashboard chrome (defaults to "Jobify")
NEXT_PUBLIC_SITE_NAME=Jobify

# Optional: path to a candidate profile file the chat endpoint uses as
# ground-truth context. Leave unset to run the chat without it.
# CANDIDATE_PROFILE_PATH=/absolute/path/to/profile.md
