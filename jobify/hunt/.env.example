ANTHROPIC_API_KEY=sk-ant-...
SERPAPI_KEY=...
RESEND_API_KEY=re_...
NOTIFY_FROM=Job Agent <jobs@vishal.pa.thak.io>
NOTIFY_TO=vishal@pa.thak.io

# JSearch — RapidAPI Google Jobs aggregator (Indeed + LinkedIn + ZipRecruiter)
# Subscribe at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=
JSEARCH_MAX_REQUESTS_PER_RUN=8
JSEARCH_NUM_PAGES=2

# 80,000 Hours job board — Algolia search-only credentials.
# Defaults are baked in; override only if 80kh rotates them. Find new
# values via DevTools on https://jobs.80000hours.org/ — search the HTML
# for "algoliaApplicationId".
ALGOLIA_80KH_APP_ID=
ALGOLIA_80KH_API_KEY=
ALGOLIA_80KH_INDEX=

# Hunter mode override (also settable via --mode CLI arg).
# local_remote = Atlanta + Remote only (default); us_wide = adds national US.
HUNTER_MODE=local_remote
