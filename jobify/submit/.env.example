# Supabase — shared with job-hunter / job-applicant (same project)
SUPABASE_URL=
SUPABASE_KEY=                          # anon key, for read-heavy ops
SUPABASE_SERVICE_ROLE_KEY=             # required for Storage downloads + bucket deletes

# Browserbase — hosted Chromium for submissions
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Anthropic — used sparingly (confirm.py post-submit verification,
# generic_stagehand adapter fallback).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Submitter policy knobs
POLL_INTERVAL_SECONDS=60               # how often to check for status=ready_to_submit jobs
MAX_CONCURRENT_SUBMISSIONS=1           # single-browser-at-a-time is safest
AUTO_SUBMIT_THRESHOLD=0.90             # below this, jobs go to needs_review
SESSION_BUDGET_SECONDS=240             # hard cap per Browserbase session
MAX_ATTEMPTS_PER_JOB=3                 # ceiling on retry before status=failed
HEADLESS=true                          # set false for local debugging against a windowed browser

# Dashboard URL — where review packets are rendered
REVIEW_DASHBOARD_URL=https://vishal.pa.thak.io/review
